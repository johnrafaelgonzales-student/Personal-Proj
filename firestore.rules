/**
 * @fileoverview This file defines the security rules for the Firestore database.
 * It uses a role-based access control system to manage permissions for different
 * types of users: Admins and Registered Visitors.
 *
 * @rules_version '2'
 */
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // These functions provide reusable logic for checking permissions.
    // ----------------------------------------------------------------------

    /**
     * Checks if the user making the request is authenticated.
     * @returns {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     * This is the primary function for enforcing that users can only access their own data.
     * @param {string} userId The user ID to check against the request's auth UID.
     * @returns {boolean} True if the request is from the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the current user has an 'Admin' role.
     * Role is determined by the existence of their user profile document
     * in the /admins collection. This is a fast, non-billable check.
     * @returns {boolean} True if the user is an admin, false otherwise.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    /**
     * Checks if the current user is a 'Registered Visitor'.
     * Role is determined by the existence of their user profile document
     * in the /registeredVisitors collection.
     * @returns {boolean} True if the user is a registered visitor, false otherwise.
     */
    function isRegisteredVisitor() {
      return isSignedIn() && exists(/databases/$(database)/documents/registeredVisitors/$(request.auth.uid));
    }
    
    /**
     * Validates the data for a new Admin document upon creation.
     * Ensures the 'id' field within the document matches the document's ID (the user's UID).
     * @param {string} adminId The UID of the admin being created.
     * @returns {boolean} True if the create data is valid.
     */
    function hasValidAdminCreateData(adminId) {
      return request.resource.data.id == adminId;
    }

    /**
     * Enforces immutability for critical fields in an Admin document during an update.
     * Specifically, it prevents the 'id' field from being changed.
     * @returns {boolean} True if the immutable fields are unchanged.
     */
    function isImmutableAdminData() {
        return request.resource.data.id == resource.data.id;
    }

    /**
     * Validates the data for a new RegisteredVisitor document upon creation.
     * Ensures the 'id' field within the document matches the document's ID (the user's UID).
     * @param {string} registeredVisitorId The UID of the visitor being created.
     * @returns {boolean} True if the create data is valid.
     */
    function hasValidVisitorCreateData(registeredVisitorId) {
      return request.resource.data.id == registeredVisitorId;
    }

    /**
     * Enforces immutability for critical fields in a RegisteredVisitor document during an update.
     * Specifically, it prevents the 'id' field from being changed.
     * @returns {boolean} True if the immutable fields are unchanged.
     */
    function isImmutableVisitorData() {
        return request.resource.data.id == resource.data.id;
    }

    /**
     * Validates the creation of a new VisitorEntry document.
     * An entry is valid if it's being created by an Admin for any user,
     * or by a Registered Visitor for themselves.
     * @returns {boolean} True if the new entry has a valid author.
     */
    function isValidVisitorEntryCreate() {
        let createdByAdmin = isAdmin() && request.resource.data.loggedByAdminUserId == request.auth.uid;
        let createdByVisitor = isRegisteredVisitor() && request.resource.data.registeredVisitorId == request.auth.uid;
        return createdByAdmin || createdByVisitor;
    }

    // ----------------------------------------------------------------------
    // Collection-level Security Rules
    // ----------------------------------------------------------------------

    /**
     * Rules for the `/admins` collection.
     * This collection stores the profiles of administrator users.
     */
    match /admins/{adminId} {
      // Admins can read their own profile or any other admin's profile.
      allow get: if isOwner(adminId) || isAdmin();
      // Only admins can list all admin profiles.
      allow list: if isAdmin();
      // A new user can create their own admin profile document. This is for initial setup.
      allow create: if isOwner(adminId) && hasValidAdminCreateData(adminId);
      // An admin can update their own profile or any other admin's profile. ID is immutable.
      allow update: if (isOwner(adminId) || isAdmin()) && resource != null && isImmutableAdminData();
      // An admin can delete their own profile or any other admin's profile.
      allow delete: if (isOwner(adminId) || isAdmin()) && resource != null;
    }

    /**
     * Rules for the `/registeredVisitors` collection.
     * This collection stores the profiles of registered visitors.
     */
    match /registeredVisitors/{registeredVisitorId} {
      // Visitors can read their own profile. Admins can read any visitor's profile.
      allow get: if isOwner(registeredVisitorId) || isAdmin();
      // Only admins can list all visitor profiles.
      allow list: if isAdmin();
      // A new user can create their own visitor profile.
      allow create: if isOwner(registeredVisitorId) && hasValidVisitorCreateData(registeredVisitorId);
      // Visitors can update their own profile. Admins can update any visitor's profile. ID is immutable.
      allow update: if (isOwner(registeredVisitorId) || isAdmin()) && resource != null && isImmutableVisitorData();
      // Visitors can delete their own profile. Admins can delete any visitor's profile.
      allow delete: if (isOwner(registeredVisitorId) || isAdmin()) && resource != null;
    }

    /**
     * Rules for the `/visitorEntries` collection.
     * This collection is the master log of all visitor activity.
     */
    match /visitorEntries/{visitorEntryId} {
      // Only admins can read individual entries or list the entire log for reporting.
      allow get, list: if isAdmin();
      // A signed-in user can create a new entry if they are an admin or a visitor creating an entry for themselves.
      allow create: if isSignedIn() && isValidVisitorEntryCreate();
      // Only admins can update log entries (e.g., to correct a mistake).
      allow update: if isAdmin() && resource != null;
      // Only admins can delete log entries.
      allow delete: if isAdmin() && resource != null;
    }
  }
}
